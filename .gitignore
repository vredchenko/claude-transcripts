# Env
.env
.env.local
.env.*.local

# Bun / Node
node_modules/
*.log
.DS_Store

# Build output
dist/
build/
*.tsbuildinfo

# Live config (instance-specific; copied from config/config.template.json)
config/config.json
config/*.local.json

