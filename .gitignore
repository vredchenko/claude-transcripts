deploy/data/

# Generated API clients (regenerated from the OpenAPI spec) ARE committed.
# packages/*/src/api/generated.ts   # uncomment if we choose not to commit them
# The OpenAPI spec is a transient build input (emitted by gen:clients, then orval'd):
openapi.json

# Local hook config / scratch
hooks/.config/
