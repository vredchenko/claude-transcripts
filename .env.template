# Copy to .env and fill in. Never commit .env.
#
# This file holds SECRETS + ENDPOINTS + image refs only. Non-secret, deployment-
# wide defaults (database/bucket NAMES, feature flags, tunables) live in `config/`
# (config.template.json → config.json) — see docs/configuration.md.
#
# ONE source for both worlds: the stack runner (scripts/stack.ts) passes this file
# to docker compose, and Bun auto-loads it for the host-run webapi/webui — so ports
# and image refs are defined once and stay coherent.
#
# The bundled dev stack (deploy/) defaults to NO AUTH for app access on localhost
# (ADR 0020) — leave the app credential fields blank. Garage still needs its
# internal cluster secrets below.

# --- Container registry (images are pulled from here) ---------------------------
# IMAGE_NS = <registry host>/<org>. Kept out of committed files (homelab-agnostic).
# e.g. ghcr.io/OWNER
# OPTIONAL: leave blank and run the stack with `--upstream` (bun run stack:up:upstream)
# to pull canonical PUBLIC images instead — no registry/mirror needed for dev.
IMAGE_NS=
# Image tags (pinned; mirror these with scripts/mirror-images.ts).
COUCHDB_TAG=3
GARAGE_TAG=v2.3.0
GARAGE_UI_TAG=1.1.0
MEILI_TAG=v1.10
MEILI_UI_TAG=latest
APP_TAG=latest

# --- Ports (dev range 7650–7661) ------------------------------------------------
WEBAPI_PORT=7650
WEBUI_PORT=7651
COUCHDB_PORT=7652
GARAGE_S3_PORT=7653
GARAGE_ADMIN_PORT=7654
GARAGE_WEBUI_PORT=7655
MEILI_PORT=7656
MEILI_UI_PORT=7657

# --- Host bindings --------------------------------------------------------------
WEBAPI_HOST=127.0.0.1
WEBUI_HOST=127.0.0.1
# Path to the prebuilt webui SPA dist (set in the prod image; unset in dev).
# CT_STATIC_DIR=

# --- CouchDB (source of truth; bundled stack = no auth) -------------------------
COUCHDB_HOST=127.0.0.1
COUCHDB_USER=
COUCHDB_PASSWORD=

# --- S3 / Garage ----------------------------------------------------------------
# App-facing S3 key (created once during the Garage bootstrap, then pasted here).
S3_ENDPOINT=http://127.0.0.1:7653
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Garage internal cluster secrets (NOT user auth). Generate: openssl rand -hex 32.
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=

# --- Meilisearch (derived search index; bundled stack = no master key) ----------
MEILI_HOST=http://127.0.0.1:7656
MEILI_API_KEY=
